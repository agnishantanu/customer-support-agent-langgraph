# ============================================================
# AI Customer Support Automation — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- LLM Provider ---
# Options: "openai" or "ibm"
LLM_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0

# --- IBM Watsonx Configuration (optional) ---
IBM_API_KEY=your-ibm-api-key-here
IBM_PROJECT_ID=your-ibm-project-id-here
IBM_URL=https://us-south.ml.cloud.ibm.com
IBM_MODEL=ibm/granite-13b-chat-v2

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- RAG / ChromaDB ---
CHROMA_PERSIST_DIR=chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_TOP_K=3
KNOWLEDGE_BASE_DIR=knowledge_base

# --- SQLite Memory ---
SQLITE_DB_PATH=memory.db

# --- FastAPI ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
